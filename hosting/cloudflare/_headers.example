# host-specific deployment config — replace with the equivalent for a new host if migrating
# Cloudflare Pages: place as `public/_headers` (or project `_headers`).
# No Strict-Transport-Security until the permanent host is locked in.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://formspree.io; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; script-src 'self' 'nonce-ZmdL9Ri87Z5PsUSMlZ0n0g'; style-src 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()
  X-Frame-Options: DENY
