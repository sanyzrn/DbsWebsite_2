# host-specific deployment config — replace with the equivalent for a new host if migrating
# ACTIVE HOST today is Vercel (/vercel.json). Use this snippet when serving `dist/` via Nginx.

# Canonical host (temporary provider subdomain → apex). Adjust server_name as needed.
# server {
#   listen 443 ssl http2;
#   server_name dbs-website-2.vercel.app;
#   return 301 https://dbsgraphic.ir$request_uri;
# }

server {
  listen 443 ssl http2;
  server_name dbsgraphic.ir;
  root /var/www/dbsgraphic/dist;   # ← point at the built `dist/` folder
  index index.html;

  # --- Security headers (no HSTS until the permanent host is locked in) ---
  # CSP: self + Formspree; inline script/style for FOUC bootstrap + JSON-LD; self-hosted fonts
  add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://formspree.io; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; script-src 'self' 'nonce-ZmdL9Ri87Z5PsUSMlZ0n0g'; style-src 'self'" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header Referrer-Policy "strict-origin-when-cross-origin" always;
  add_header Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()" always;
  add_header X-Frame-Options "DENY" always;

  # Prefer exact files / clean URLs (matches vercel cleanUrls)
  try_files $uri $uri/ $uri.html =404;

  # True 404 status with locale-aware bodies
  error_page 404 /404.html;
  location = /404.html {
    internal;
  }

  # English unmatched paths should use the English 404 document
  location ^~ /en/ {
    try_files $uri $uri/ $uri.html /en/404.html;
    error_page 404 /en/404.html;
  }

  location = /en/404.html {
    internal;
  }
}
