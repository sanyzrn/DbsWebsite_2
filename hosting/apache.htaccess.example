# Rename this file to `.htaccess` and upload it to your web root (the same folder as
# index.html) alongside the rest of the dist/ build output — it must sit at the root
# of the deployed site, not inside a subfolder.
#
# Requires:
#   - mod_rewrite (for filesystem-first checks before 404 fallback)
#   - mod_headers (for security headers below — some shared hosts disable this by
#     default; verify it is enabled before relying on Header set directives)
#
# Host-agnostic requirements mirrored from hosting/README.md (same as
# Vercel / Netlify / Cloudflare / Nginx examples):
#   1. True HTTP 404 for unmatched paths (en → en/404.html, else 404.html)
#   2. Security headers on every response (no HSTS until TLS/domain are locked in)
#
# ACTIVE HOST: Apache via manual FTP upload (until deploy automation is set up).
# Place this next to the built files from `npm run build` (dist/ contents).

DirectoryIndex index.html

# Locale-aware 404 bodies (real HTTP 404 status — not soft-404).
# Prefer Apache 2.4 expressions; see the directory-level alternative in comments below
# if your host does not support <If>.
<If "%{REQUEST_URI} =~ m#^/en(?:/|$)#">
  ErrorDocument 404 /en/404.html
</If>
<Else>
  ErrorDocument 404 /404.html
</Else>

# Directory-level alternative (no <If> expressions):
#   Also drop a tiny .htaccess inside the prerendered `en/` folder containing only:
#     ErrorDocument 404 /en/404.html
#   …and keep the root ErrorDocument 404 /404.html for everything else.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Existing files and directories (prerendered HTML routes, assets, images, fonts)
  # must be served normally — only fall through to 404 when neither exists.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^/en(?:/|$)
  RewriteRule ^ - [R=404,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ - [R=404,L]
</IfModule>

# --- Security headers (requires mod_headers) ---
# Do NOT add Strict-Transport-Security until the permanent domain + TLS are stable.
<IfModule mod_headers.c>
  # Content-Security-Policy — generated at build by scripts/prerender.mjs (scripts/csp.mjs).
  # Do not hand-edit the Header line below; re-run `npm run build` to refresh nonce + hashes.
  #   default-src 'self'              — deny by default; only same-origin unless overridden
  #   base-uri 'self'                 — restrict <base> targets
  #   object-src 'none'               — no plugins
  #   frame-ancestors 'none'          — clickjacking protection (pairs with X-Frame-Options)
  #   form-action 'self' https://formspree.io
  #                                   — form posts (Formspree when VITE_FORMSPREE_ID is set)
  #   script-src 'self' 'nonce-…'     — app bundles + FOUC/theme + JSON-LD (per-build nonce)
  #   style-src 'self' [+ hashes]     — bundled CSS only; inline style attrs removed from app
  #   img-src 'self' data: blob:      — site images + inline/data URLs
  #   font-src 'self' data:           — self-hosted @fontsource fonts (no Google Fonts CDN)
  #   connect-src 'self' https://formspree.io
  #                                   — contact form POST when Formspree is configured
  #   worker-src 'self' blob:         — PWA service worker + any blob workers
  #   manifest-src 'self'             — web app manifest
  #   upgrade-insecure-requests       — prefer HTTPS subresources
  Header set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://formspree.io; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests; script-src 'self' 'nonce-ZmdL9Ri87Z5PsUSMlZ0n0g'; style-src 'self'"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
  Header set X-Frame-Options "DENY"
</IfModule>
