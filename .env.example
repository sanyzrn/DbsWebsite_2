# Public site origin (no trailing slash). Used for canonical, Open Graph, Twitter,
# JSON-LD Person.url, robots.txt Sitemap, and sitemap.xml <loc> entries.
# Default when unset: https://dbsgraphic.ir
SITE_URL=https://dbsgraphic.ir

# Formspree form id for the interactive contact form.
# When unset, the UI shows a static direct-email message (builds still succeed).
# VITE_FORMSPREE_ID=
