# Public site origin (no trailing slash). Used for canonical, Open Graph, Twitter,
# JSON-LD Person.url, robots.txt Sitemap, and sitemap.xml <loc> entries.
# Default when unset: https://dbsgraphic.ir
SITE_URL=https://dbsgraphic.ir

# Required for production builds: Formspree form id for the contact form.
# Without it, production `vite build` fails unless the deliberate mailto escape hatch below is set.
# VITE_FORMSPREE_ID=

# Deliberate exception: allow production builds to keep the truncated mailto: fallback
# when Formspree is not configured (CI / local preview). Set to 1 only intentionally.
# ALLOW_MAILTO_CONTACT_FALLBACK=1
