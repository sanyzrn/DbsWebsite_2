{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:seo": "node scripts/generate-seo-files.mjs",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "check:urls": "npm run generate:seo && node scripts/check-urls.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "optimize:image": "node scripts/optimize-image.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:deploy": "node scripts/check-deploy.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:i18n": "node --experimental-strip-types scripts/check-i18n-parity.mjs",
    "build": "npm run validate:content && npm run check:i18n && npm run check:urls && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs && node scripts/generate-sw.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "check:pwa": "node scripts/check-pwa.mjs"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.3.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/vazirmatn": "^5.3.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@react-three/fiber": "^9.6.1",
    "clsx": "2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.25.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.18.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwind-merge": "3.6.0",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "5.1.1",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-build": "^7.4.1"
  }
}
